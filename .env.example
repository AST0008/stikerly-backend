# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=stikerly

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_KEY=changeme

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Meme auto-fetch: Reddit ───────────────────────────────────────────────────
# Comma-separated list of subreddits to fetch from (no r/ prefix).
MEME_REDDIT_SUBREDDITS=MemeEconomy,memes,dankmemes
# Number of posts to fetch per subreddit per run (max 100).
MEME_REDDIT_LIMIT=15
# Time window for Reddit "top" posts: hour | day | week | month | year | all
MEME_REDDIT_TIMEFRAME=day

# ── Meme auto-fetch: GIPHY ────────────────────────────────────────────────────
# Get a free key at https://developers.giphy.com/
# Leave blank to disable GIPHY fetching.
GIPHY_API_KEY=
# Number of GIFs to fetch per run.
MEME_GIPHY_LIMIT=10
